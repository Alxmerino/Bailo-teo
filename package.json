{
  "name": "bailoteo",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -F web build",
    "preview": "pnpm -F web preview",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > packages/shared/src/database.types.ts",
    "deploy": "pnpm build && npx wrangler pages deploy apps/web/dist --project-name bailoteo"
  },
  "devDependencies": {
    "supabase": "^1.207.9"
  }
}
